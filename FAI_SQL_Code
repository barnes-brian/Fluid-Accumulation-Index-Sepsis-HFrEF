##########################Restrict Septic Population to those with HFrEF & Limiting to First Hospitalization##########################


--Identify those with heart failure with reduced ejection fraction--

SELECT *
FROM `physionet-data.mimiciv_3_1_hosp.d_icd_diagnoses`
WHERE icd_version= 10 AND (LOWER(long_title) LIKE '%heart%disease%' OR LOWER(long_title) LIKE '%heart%failure%' OR LOWER(long_title) LIKE '%cardiomyopathy%');
SELECT *
FROM `physionet-data.mimiciv_3_1_hosp.d_icd_diagnoses`
WHERE LOWER(icd_code) IN (
"42820","42821","42822","42823","42840","42841","42842","42843","i502","i5020","i5021","i5022","i5023","i504","i5040",
"i5041","i5042","i5043", "i5084");


CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full` AS 
SELECT s.*
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_patients` s
WHERE s.hadm_id IN
(SELECT DISTINCT d.hadm_id
FROM `physionet-data.mimiciv_3_1_hosp.diagnoses_icd` d       
WHERE  LOWER(icd_code) IN (
"42820","42821","42822","42823","42840","42841","42842","42843","i502","i5020","i5021","i5022","i5023","i504","i5040",
"i5041","i5042","i5043", "i5084"));


SELECT COUNT (DISTINCT subject_id) AS n_pts,
       COUNT (DISTINCT hadm_id) AS n_hadm,
       COUNT (DISTINCT stay_id) AS n_icustays
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full`;
         
--Limiting our dataset to the first hospitalization for each patient--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_1` AS
