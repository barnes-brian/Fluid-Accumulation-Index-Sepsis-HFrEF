FROM (
  SELECT
    s.*,
    ROW_NUMBER() OVER (
      PARTITION BY subject_id
        ORDER BY intime ASC
    ) AS first_appearance
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full` s
)
