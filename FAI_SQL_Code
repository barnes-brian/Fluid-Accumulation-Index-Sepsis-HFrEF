##########################Bringing in Outcomes (In-Hospital Mortality, AKI, CRRT)##########################

--------------------------------------------MERGING IN-HOSPITAL MORTALITY DATA--------------------------------------------------
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_2` AS
