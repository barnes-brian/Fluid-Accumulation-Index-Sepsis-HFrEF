##########################Sepsis timing flag##########################

--Generating flag to determine if each patient had SOFA 2+ and suspicion of infection in the first 48 hours of ICU stay--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_29` AS
SELECT *, 
CASE 
  WHEN sofa_time_sepdx BETWEEN intime AND admitted_48_hrs THEN 1 --if the time SOFA was first 2+ is within the first 48hrs--
  ELSE 0 
  END AS sofa_sepsis_first48,
CASE 
  WHEN susp_infection_time_sepdx BETWEEN intime AND admitted_48_hrs THEN 1 --if the time infection was suspected is within the first 48 hrs--
  ELSE 0
  END AS susp_infection_first48
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_28`;



#########################Calculate fluid balance in the first 48 hours after sepsis onset as per Dong et al. code ##########################


###Apply exclusion criteria###
--ESRD 
--ICU los <= 2.0 days
--Prior AKI (note that only prior AKIs occurring at BIDMC will be captured)
--Not receiving pressors in first 48h of ICU admission
--Not meeting the following criteria in first 48h of ICU admission: SOFA 2+ and suspicion of infection--

SELECT s.*
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_29` s
WHERE (s.sofa_sepsis_first48=1 AND s.susp_infection_first48=1 AND s.ned_received= 1 AND s.prior_AKI_flag= 0 AND s.los > 2.0 AND s.hadm_id NOT IN
(SELECT DISTINCT d.hadm_id
  FROM `physionet-data.mimiciv_3_1_hosp.diagnoses_icd` d 
    WHERE LOWER(d.icd_code) IN ("40301","40311","40391","40402","40403","40412","40413","40492","40493",
    "5855","5856","i120","i1311","i132","n185","n186"))); --Final study population--


--Creating a dataset with our analytic sample that includes sepsis onset time--

CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample` AS
SELECT s.*, GREATEST(susp_infection_time_sepdx, sofa_time_sepdx) AS sepsis_onset_datetime
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_29` s
WHERE (s.sofa_sepsis_first48=1 AND s.susp_infection_first48=1 AND s.ned_received= 1 AND s.prior_AKI_flag= 0 AND s.los > 2.0 AND s.hadm_id NOT IN
(SELECT DISTINCT d.hadm_id
  FROM `physionet-data.mimiciv_3_1_hosp.diagnoses_icd` d 
    WHERE LOWER(d.icd_code) IN ("40301","40311","40391","40402","40403","40412","40413","40492","40493",
    "5855","5856","i120","i1311","i132","n185","n186"))); --Final study population--


--All volumetric input events that occurred in our analytic sample--
--We will reference this list in our modified fluid balance code from Dong et al--
SELECT DISTINCT amountuom
FROM `physionet-data.mimiciv_3_1_icu.inputevents` ;

SELECT DISTINCT i.itemid, d.label
FROM `physionet-data.mimiciv_3_1_icu.inputevents` i
LEFT JOIN `physionet-data.mimiciv_3_1_icu.d_items` d
  ON i.itemid = d.itemid
WHERE i.stay_id IN(
    SELECT DISTINCT s.stay_id
        FROM `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample` s)
          AND i.amountuom in ('mL', 'L','nL', 'pL', 'µL' ); --Excluding itemid 226361 "Pre-Admission/Non-ICU Intake" from our list--



--All output events that occurred in our analytic sample--
--We will reference this list in our modified fluid balance code from Dong et al--
SELECT DISTINCT o.itemid, d.label, o.valueuom
FROM `physionet-data.mimiciv_3_1_icu.outputevents` o
LEFT JOIN `physionet-data.mimiciv_3_1_icu.d_items` d
  ON o.itemid = d.itemid
WHERE o.stay_id IN(
    SELECT DISTINCT s.stay_id
        FROM `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample` s); --Excluding itemid 226633 "Pre-Admission" from our list--

--Outputevents table does not include hemodialysis outputs, so we will need to reference the chartevents table to incorporate these itemids--

--Identifying dialysis itemids to then search in chartevents--
SELECT *
FROM physionet-data.mimiciv_3_1_icu.d_items
WHERE LOWER (label) LIKE '%hemodial%'
  OR LOWER (label) LIKE '%dialys%'
  OR LOWER (label) LIKE '%ultrafi%'
  OR LOWER (label) LIKE '%hd%';


SELECT DISTINCT c.itemid, d.label, c.valueuom
FROM `physionet-data.mimiciv_3_1_icu.chartevents` c
LEFT JOIN `physionet-data.mimiciv_3_1_icu.d_items` d
  ON c.itemid=d.itemid
   WHERE d.itemid IN(226457, 226499); --Both charted in mLs--


SELECT DISTINCT a.stay_id
  FROM `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample` a
  LEFT JOIN `physionet-data.mimiciv_3_1_icu.chartevents` c
  ON a.stay_id = c.stay_id
  WHERE c.itemid IN (226457,226499)
  AND c.charttime BETWEEN a.sepsis_onset_datetime AND (DATETIME_ADD(a.sepsis_onset_datetime,interval '2' DAY)); --Our analytic sample does have hemodialysis output charted, so we will need to update our fluid balance code to consider this--


--Before running the fluid balance code, we need to create a modified icustays table that includes sepsis onset time--
CREATE OR REPLACE TABLE  `mimic-iv-ext-2025.FAI_Sepsis.icustays_modified` AS
  SELECT i.stay_id, a.sepsis_onset_datetime
    FROM `physionet-data.mimiciv_3_1_icu.icustays` i
    LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample` a
      ON i.stay_id = a.stay_id;


  
--Calculate fluid balance for each patient--
--The following code has been modified from the Dong et al article: 
--https://www.frontiersin.org/journals/medicine/articles/10.3389/fmed.2022.714384/full#supplementary-material--
--1)All inclusion/exclusion criteria were applied
--2)Pulled all inputevents item IDs that occurred in our analytic sample
--3)Pulled all outputevents item IDs that occurred in our analytic sample
--4)Modified the Dong et al. fluid balance code to use our population-specific input and output events
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample_fb_sepsis_onset` AS 
with t1 as --t1 is inputevents within 2 days after sepsis onset 
(select p1.stay_id, 
        p1.starttime, 
        p1.itemid,
        p1.amountuom,
        p1.ordercategoryname,
        p1.secondaryordercategoryname,
   round(case
      when p1.amountuom='L' then p1.amount*1000
                    when p1.amountuom='mL' then p1.amount
                    else NULL end) as amount
      from `physionet-data.mimiciv_3_1_icu.inputevents` p1 
       left join `mimic-iv-ext-2025.FAI_Sepsis.icustays_modified` p2
     on p1.stay_id = p2.stay_id 
     where p1.starttime between p2.sepsis_onset_datetime and (DATETIME_ADD(p2.sepsis_onset_datetime,interval '2' DAY)) 
),
t2 as --t2 is dialysis outputs within 2 days after sepsis onset(chartevents)
(select p1.stay_id, p1.itemid, p1.valuenum
   from `physionet-data.mimiciv_3_1_icu.chartevents` p1
    left join `mimic-iv-ext-2025.FAI_Sepsis.icustays_modified` p2
      on p1.stay_id= p2.stay_id
        where p1.charttime between p2.sepsis_onset_datetime and (DATETIME_ADD(p2.sepsis_onset_datetime,interval '2' DAY)) 
),
t3 as  --t3 is outputevents within 2 days after sepsis onset
(select tmp.stay_id,tmp.charttime,tmp.itemid,tmp.label,tmp.value from
  (select p1.stay_id,
        p1.charttime,
        p1.itemid,
        p2.label,
        p1.value
       from `physionet-data.mimiciv_3_1_icu.outputevents` p1
       left join `physionet-data.mimiciv_3_1_icu.d_items` p2
     on p1.itemid = p2.itemid
     ) tmp
    left join `mimic-iv-ext-2025.FAI_Sepsis.icustays_modified` p3
    on p3.stay_id = tmp.stay_id
    where (tmp.charttime between p3.sepsis_onset_datetime and (DATETIME_ADD(p3.sepsis_onset_datetime,interval '2' DAY)) --within 2 days after sepsis onset time 
          and tmp.stay_id in (select stay_id from `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample`)) --select analytic sample
 ),
