--Day 5--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.ned_d5_max` AS
WITH ned AS(
    SELECT s.*,n.starttime, n.endtime, n.norepinephrine_equivalent_dose
      FROM `physionet-data.mimiciv_3_1_derived.norepinephrine_equivalent_dose` n
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_27` s
          ON n.stay_id = s.stay_id
)
SELECT ned.stay_id,MAX(ned.norepinephrine_equivalent_dose) AS day5_peak_NED
FROM ned ned
WHERE ned.starttime < ned.fivedays_admitted
          AND ned.endtime > ned.fourdays_admitted
GROUP BY ned.stay_id;

--Day 6--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.ned_d6_max` AS
WITH ned AS(
    SELECT s.*,n.starttime, n.endtime, n.norepinephrine_equivalent_dose
      FROM `physionet-data.mimiciv_3_1_derived.norepinephrine_equivalent_dose` n
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_27` s
          ON n.stay_id = s.stay_id
)
SELECT ned.stay_id,MAX(ned.norepinephrine_equivalent_dose) AS day6_peak_NED
FROM ned ned
WHERE ned.starttime < ned.sixdays_admitted
          AND ned.endtime > ned.fivedays_admitted
GROUP BY ned.stay_id;

--Day 7--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.ned_d7_max` AS
WITH ned AS(
    SELECT s.*,n.starttime, n.endtime, n.norepinephrine_equivalent_dose
      FROM `physionet-data.mimiciv_3_1_derived.norepinephrine_equivalent_dose` n
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_27` s
          ON n.stay_id = s.stay_id
)
SELECT ned.stay_id,MAX(ned.norepinephrine_equivalent_dose) AS day7_peak_NED
FROM ned ned
WHERE ned.starttime < ned.sevendays_admitted
          AND ned.endtime > ned.sixdays_admitted
GROUP BY ned.stay_id;

--Merging all peak NED variables together--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_28` AS
SELECT s.*,d1.day1_peak_NED, d2.day2_peak_NED, d3.day3_peak_NED, d4.day4_peak_NED, d5.day5_peak_NED, d6.day6_peak_NED, d7.day7_peak_NED
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_27` s
  LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.ned_d1_max` d1 
    ON s.stay_id= d1.stay_id
      LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.ned_d2_max` d2
        ON s.stay_id = d2.stay_id
          LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.ned_d3_max` d3
            ON s.stay_id = d3.stay_id
              LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.ned_d4_max` d4
                ON s.stay_id = d4.stay_id
                  LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.ned_d5_max` d5
                    ON s.stay_id = d5.stay_id
                      LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.ned_d6_max` d6
                        ON s.stay_id = d6.stay_id
                          LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.ned_d7_max` d7
                            ON s.stay_id = d7.stay_id;


##########################Step 14: Sepsis timing flag##########################

--Generating flag to determine if each patient had SOFA 2+ and suspicion of infection in the first 48 hours of ICU stay--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_29` AS
SELECT *, 
CASE 
  WHEN sofa_time_sepdx BETWEEN intime AND admitted_48_hrs THEN 1 --if the time SOFA was first 2+ is within the first 48hrs--
  ELSE 0 
  END AS sofa_sepsis_first48,
CASE 
  WHEN susp_infection_time_sepdx BETWEEN intime AND admitted_48_hrs THEN 1 --if the time infection was suspected is within the first 48 hrs--
  ELSE 0
  END AS susp_infection_first48
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_28`;



##########################Step 15: Apply exclusion criteria##########################
--ESRD 
--ICU los <= 2.0 days
--Prior AKI (note that only prior AKIs occurring at BIDMC will be captured)
--Not receiving pressors in first 48h of ICU admission
--Not meeting the following criteria in first 48h of ICU admission: SOFA 2+ and suspicion of infection--

SELECT s.*
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_29` s
WHERE (s.sofa_sepsis_first48=1 AND s.susp_infection_first48=1 AND s.ned_received= 1 AND s.prior_AKI_flag= 0 AND s.los > 2.0 AND s.hadm_id NOT IN
(SELECT DISTINCT d.hadm_id
  FROM `physionet-data.mimiciv_3_1_hosp.diagnoses_icd` d 
    WHERE LOWER(d.icd_code) IN ("40301","40311","40391","40402","40403","40412","40413","40492","40493",
    "5855","5856","i120","i1311","i132","n185","n186"))); --Final study population--
