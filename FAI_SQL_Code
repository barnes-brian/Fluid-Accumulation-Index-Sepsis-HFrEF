--Creating variable to flag (0/1) patients with AKI based on dx codes--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_3` AS
SELECT s.*,
CASE 
  WHEN s.hadm_id IN (
      SELECT DISTINCT (i.hadm_id)
          FROM `physionet-data.mimiciv_3_1_hosp.diagnoses_icd` i
             WHERE LOWER(i.icd_code) IN ('5845', '5846', '5847', '5848', '5849', '66930','66932', '66934' 'n17','n170', 'n171', 'n172', 'n178','n179','n990', 'o904'))
    THEN 1 
    ELSE 0
    END AS aki_dx_code
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_2` s;

----------------------------------------------DEFINING AKI OUTCOME BASED ON KDIGO STAGE (CREATININE CRITERIA)-----------------------------------------------------
--Creating a table that merges in creatinine value, creatinine KDIGO score, and creatinine KDIGO time for each patient--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_4` AS
SELECT s.*, k.aki_stage_creat, k.creat, k.charttime AS charttime_kdigo_creat
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_3` s
LEFT JOIN `physionet-data.mimiciv_3_1_derived.kdigo_stages` k
 ON s.stay_id = k.stay_id
 AND k.aki_stage_creat IS NOT NULL;
 
--Creating a timestamp for the 24 hour mark post-ICU admission in case we want to use that as our starting point to look for AKI--
--Creating another timestamp for the 48 hour mark post-ICU admission to define AKI timeframe--
--Also adding a boundary for 7 days post-admission to use that as the upper limit of our search for AKI dx--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_5` AS
SELECT *, DATETIME_ADD(intime, INTERVAL 24 HOUR) AS oneday_admitted,DATETIME_ADD(intime, INTERVAL 48 HOUR) AS admitted_48_hrs, DATETIME_ADD(intime, INTERVAL 7 DAY) AS sevendays_admitted
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_4`;


--AKI Y/N Using Hour 48- Hour 168 as diagnostic window (Day 3 - Day 7)--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.aki_creatinine` AS 
SELECT a.stay_id,
  MAX (
      CASE 
        WHEN a.charttime_kdigo_creat BETWEEN a.admitted_48_hrs AND  a.sevendays_admitted 
          AND ( 
              a.aki_stage_creat IN (1,2,3))--KDIGO 1, 2, or 3 (AKI present) within days 3-7--
          THEN 1 
        WHEN a.charttime_kdigo_creat BETWEEN a.admitted_48_hrs AND  a.sevendays_admitted 
          AND ( 
             a.aki_stage_creat IN (0))--KDIGO 0 (no AKI) within days 3-7--
          THEN 0
        WHEN a.charttime_kdigo_creat NOT BETWEEN a.admitted_48_hrs AND a.sevendays_admitted
          THEN 0 --Creatinine measured outside of days 3-7 of ICU admission = no AKI --
        ELSE NULL --If missing creatinine KDIGO data, AKI outcome variable is NULL--
      END)
    AS AKI_days_3_through_7_admission_creat
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_5` a 
  GROUP BY a.stay_id;
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_6` AS 
SELECT a.*, b.AKI_days_3_through_7_admission_creat
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_5` a
LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.aki_creatinine` b
ON a.stay_id = b.stay_id;

