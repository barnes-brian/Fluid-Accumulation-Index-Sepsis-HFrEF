          FROM `physionet-data.mimiciv_3_1_hosp.diagnoses_icd` i
             WHERE LOWER(i.icd_code) IN ('5845', '5846', '5847', '5848', '5849', '66930','66932', '66934' 'n17','n170', 'n171', 'n172', 'n178','n179','n990', 'o904'))
    THEN 1 
    ELSE 0
    END AS aki_dx_code
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_2` s;

----------------------------------------------DEFINING AKI OUTCOME BASED ON KDIGO STAGE (CREATININE CRITERIA)-----------------------------------------------------
--Creating a table that merges in creatinine value, creatinine KDIGO score, and creatinine KDIGO time for each patient--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_4` AS
SELECT s.*, k.aki_stage_creat, k.creat, k.charttime AS charttime_kdigo_creat
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_3` s
LEFT JOIN `physionet-data.mimiciv_3_1_derived.kdigo_stages` k
 ON s.stay_id = k.stay_id
 AND k.aki_stage_creat IS NOT NULL;
 
--Creating a timestamp for the 24 hour mark post-ICU admission in case we want to use that as our starting point to look for AKI--
--Creating another timestamp for the 48 hour mark post-ICU admission to define AKI timeframe--
--Also adding a boundary for 7 days post-admission to use that as the upper limit of our search for AKI dx--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_5` AS
SELECT *, DATETIME_ADD(intime, INTERVAL 24 HOUR) AS oneday_admitted,DATETIME_ADD(intime, INTERVAL 48 HOUR) AS admitted_48_hrs, DATETIME_ADD(intime, INTERVAL 7 DAY) AS sevendays_admitted
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_4`;


--AKI Y/N Using Hour 48- Hour 168 as diagnostic window (Day 3 - Day 7)--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.aki_creatinine` AS 
SELECT a.stay_id,
  MAX (
      CASE 
        WHEN a.charttime_kdigo_creat BETWEEN a.admitted_48_hrs AND  a.sevendays_admitted 
          AND ( 
              a.aki_stage_creat IN (1,2,3))--KDIGO 1, 2, or 3 (AKI present) within days 3-7--
          THEN 1 
        WHEN a.charttime_kdigo_creat BETWEEN a.admitted_48_hrs AND  a.sevendays_admitted 
          AND ( 
             a.aki_stage_creat IN (0))--KDIGO 0 (no AKI) within days 3-7--
          THEN 0
        WHEN a.charttime_kdigo_creat NOT BETWEEN a.admitted_48_hrs AND a.sevendays_admitted
          THEN 0 --Creatinine measured outside of days 3-7 of ICU admission = no AKI --
        ELSE NULL --If missing creatinine KDIGO data, AKI outcome variable is NULL--
      END)
    AS AKI_days_3_through_7_admission_creat
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_5` a 
  GROUP BY a.stay_id;
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_6` AS 
SELECT a.*, b.AKI_days_3_through_7_admission_creat
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_5` a
LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.aki_creatinine` b
ON a.stay_id = b.stay_id;

--Editing the table to keep only the first observation for each patient. At this time, we aren't interested in the measurements themselves, just whether or not the patient received CRRT (the syntax pulled every instance of CRRT for each patient, we just need the Y/N summary of that data)--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_7` AS
SELECT * 
  FROM (
      SELECT s.*, ROW_NUMBER() OVER ( 
        PARTITION BY s.stay_id ORDER BY s.stay_id) AS row_num FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_6` s ) 
        WHERE row_num = 1; 

----------------------------------------------DEFINING AKI OUTCOME BASED ON KDIGO STAGE (URINE OUTPUT CRITERIA)-----------------------------------------------------

--Creating a table that merges in urine output value, urine output KDIGO score, and urine output KDIGO time for each patient--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_8` AS
SELECT s.*, k.aki_stage_uo, k.uo_rt_6hr, k.uo_rt_12hr, k.uo_rt_24hr, k.charttime AS charttime_kdigo_uo
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_7` s
LEFT JOIN `physionet-data.mimiciv_3_1_derived.kdigo_stages` k
 ON s.stay_id = k.stay_id
 AND k.aki_stage_uo IS NOT NULL;
 
--AKI Y/N Using 48 Hour - Day 7 ICU window, Urine Output Criteria--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.aki_uo` AS 
SELECT a.stay_id,
  MAX (
      CASE 
        WHEN a.charttime_kdigo_uo BETWEEN a.admitted_48_hrs AND  a.sevendays_admitted 
          AND ( 
              a.aki_stage_uo IN (1,2,3))--KDIGO 1, 2, or 3 (AKI present) within days 3-7--
          THEN 1 
        WHEN a.charttime_kdigo_uo BETWEEN a.admitted_48_hrs AND  a.sevendays_admitted 
          AND ( 
             a.aki_stage_uo IN (0))--KDIGO 0 (no AKI) within days 3-7--
          THEN 0
        WHEN a.charttime_kdigo_uo NOT BETWEEN a.admitted_48_hrs AND a.sevendays_admitted
          THEN 0 --Urine output measured outside of days 1-7 of ICU admission = no AKI --
        ELSE NULL --If missing urine ouput KDIGO data, AKI outcome variable is NULL--
      END)
    AS AKI_days_3_through_7_admission_uo  
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_8` a 
  GROUP BY a.stay_id;

CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_9` AS 
SELECT a.*, b.AKI_days_3_through_7_admission_uo
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_8` a
LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.aki_uo` b
ON a.stay_id = b.stay_id;



----------------------------------------------DEFINING CRRT OUTCOME -----------------------------------------------------
--Editing table to keep one observation per patient. At this time, we aren't interested in the measurements themselves, just whether or not the patient had an AKI--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_10` AS
SELECT * 
  FROM (
      SELECT s.*, ROW_NUMBER() OVER ( 
        PARTITION BY s.stay_id ORDER BY s.stay_id) AS rn FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_9` s ) 
        WHERE rn = 1; 

--Creating a table that merges in CRRT KDIGO score and CRRT KDIGO time for each patient--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_11` AS
SELECT s.*, k.aki_stage_crrt, k.charttime AS charttime_kdigo_crrt
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_10` s
LEFT JOIN `physionet-data.mimiciv_3_1_derived.kdigo_stages` k
 ON s.stay_id = k.stay_id
 AND k.aki_stage_crrt IS NOT NULL;

--CRRT Y/N Using 48 Hour - Day 7 ICU window, KDIGO TABLE --
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.CRRT_outcome_kdigo` AS 
SELECT a.stay_id,
  MAX (
      CASE 
        WHEN a.charttime_kdigo_crrt BETWEEN a.admitted_48_hrs AND  a.sevendays_admitted 
          AND ( 
              a.aki_stage_crrt IN (1,2,3))--KDIGO 1, 2, or 3 (CRRT present) within days 3-7--
          THEN 1 
        WHEN a.charttime_kdigo_crrt BETWEEN a.admitted_48_hrs AND  a.sevendays_admitted 
          AND ( 
             a.aki_stage_crrt IN (0, NULL))--KDIGO 0/NULL (CRRT not received) within days 3-7--
          THEN 0
        WHEN a.charttime_kdigo_crrt NOT BETWEEN a.admitted_48_hrs AND a.sevendays_admitted
          THEN 0 --CRRT occurring outside of our timeframe of interest = no outcome --
        ELSE 0
      END) 
    AS CRRT_days_3_through_7_admission,
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_11` a 
  GROUP BY a.stay_id;


CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_12` AS 
SELECT a.*, b.CRRT_days_3_through_7_admission
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_11` a
LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.CRRT_outcome_kdigo` b
ON a.stay_id = b.stay_id;



##########################Creating a flag for prior AKI##########################

--Checking to see if patients in our study population have had an AKI prior to admission of interest--
--Note that this will only capture prior AKIs that have occurred at BIDMC during the timeframe of MIMIC data collection--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.prior_AKI` AS 
SELECT a.subject_id,
  MAX (
    CASE 
        WHEN b.charttime > a.intime THEN 0 --If all of your KDIGO measurements are > ICU admit time, you get a 0--
        WHEN b.charttime < a.intime --If KDIGO measurement before ICU admit time AND you have a stage of 1, 2, or 3, you get a 1 (prior AKI)--
          AND ( 
            b.aki_stage_creat IN (1,2,3)
            OR b.aki_stage_uo IN (1,2,3)
            OR b.aki_stage_crrt IN (1,2,3)
            OR b.aki_stage IN (1,2,3)
            OR b.aki_stage_smoothed IN (1,2,3))
          THEN 1 
        WHEN b.charttime < a.intime --If KDIGO measurement before ICU admit time AND all stages are 0, you get a 0 (no prior AKI)
          AND (
            b.aki_stage_creat IN (0)
            AND b.aki_stage_uo IN (0)
            AND b.aki_stage_crrt IN (0)
            AND b.aki_stage IN (0)
            AND b.aki_stage_smoothed IN (0))
          THEN 0
        ELSE NULL
      END)
    AS prior_AKI_flag          
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_12` a 
  LEFT JOIN `physionet-data.mimiciv_3_1_derived.kdigo_stages` b
    ON a.subject_id = b.subject_id
  GROUP BY a.subject_id;

CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_13` AS
SELECT a.*, b.prior_AKI_flag
  FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_12` a 
    INNER JOIN `mimic-iv-ext-2025.FAI_Sepsis.prior_AKI` b
      ON a.subject_id = b.subject_id;



--Editing the final table to keep only the first observation for each patient. At this time, we aren't interested in the measurements themselves, just whether or not the patient received CRRT (the syntax pulled every instance of CRRT for each patient, we just need the Y/N summary of that data)--

CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_14` AS
SELECT * 
  FROM (
      SELECT s.*, ROW_NUMBER() OVER ( 
        PARTITION BY s.stay_id ORDER BY s.stay_id) AS row_numb FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_13` s ) 
        WHERE row_numb = 1; 




##########################Severity of illness and comorbidity scores##########################

--Pulling in data on severity of illness/comorbidity score (SOFA, Charlson comorbidity index, and APS III)--

