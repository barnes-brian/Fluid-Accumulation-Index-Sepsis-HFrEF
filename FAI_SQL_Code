    SELECT s.*,n.starttime, n.endtime, n.norepinephrine_equivalent_dose
      FROM `physionet-data.mimiciv_3_1_derived.norepinephrine_equivalent_dose` n
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_27` s
          ON n.stay_id = s.stay_id
)
SELECT ned.stay_id,MAX(ned.norepinephrine_equivalent_dose) AS day3_peak_NED
FROM ned ned
WHERE ned.starttime < ned.threedays_admitted
          AND ned.endtime > ned.admitted_48_hrs
GROUP BY ned.stay_id;

--Day 4--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.ned_d4_max` AS
WITH ned AS(
    SELECT s.*,n.starttime, n.endtime, n.norepinephrine_equivalent_dose
      FROM `physionet-data.mimiciv_3_1_derived.norepinephrine_equivalent_dose` n
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_27` s
          ON n.stay_id = s.stay_id
