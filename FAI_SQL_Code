--Weight--
--Need so we can calculate fluid balance in mL/kg--

--https://github.com/MIT-LCP/mimic-code/blob/main/mimic-iv/concepts/firstday/first_day_weight.sql--
-- This query extracts weights for adult ICU patients on their first ICU day.
-- It does *not* use any information after the first ICU day, as weight is
-- sometimes used to monitor fluid balance.
-- The MIMIC-III version used echodata but this isn't available in MIMIC-IV.

CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.admitweight` AS
SELECT
    ie.subject_id
    , ie.stay_id
    , AVG(
        CASE WHEN weight_type = 'admit' THEN ce.weight ELSE NULL END
    ) AS weight_admit
    , AVG(ce.weight) AS weight
    , MIN(ce.weight) AS weight_min
    , MAX(ce.weight) AS weight_max
FROM `physionet-data.mimiciv_3_1_icu.icustays` ie
-- admission weight
LEFT JOIN `physionet-data.mimiciv_3_1_derived.weight_durations` ce
    ON ie.stay_id = ce.stay_id
        -- we filter to weights documented during or before the 1st day
        AND ce.starttime <= DATETIME_ADD(ie.intime, INTERVAL '1' DAY)
GROUP BY ie.subject_id, ie.stay_id
;

CREATE OR REPLACE TABLE  `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_25` AS
SELECT s.*, w.weight AS average_d1_weight, w.weight_admit AS icuadmit_weight, w.weight_min min_d1_weight, w.weight_max max_d1_weight
  FROM  `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_24` s
    LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.admitweight` w
      ON s.stay_id = w.stay_id;

##########################Step 12: Bringing in vasopressor frequencies##########################

--Need to create table for vasopressin (only pressor not present in the derived module)--
--https://github.com/MIT-LCP/mimic-code/blob/main/mimic-iv/concepts/medication/vasopressin.sql--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.vasopressin_alldata` AS
SELECT
    stay_id, linkorderid
    -- three rows in units/min, rest in units/hour
    -- the three rows in units/min look reasonable and
    -- fit with the patient course
    -- convert all rows to units/hour
    , CASE WHEN rateuom = 'units/min' THEN rate * 60.0
        ELSE rate END AS vaso_rate
    , amount AS vaso_amount
    , starttime
    , endtime
FROM `physionet-data.mimiciv_3_1_icu.inputevents`
WHERE itemid = 222315; -- vasopressin
--Previously created flags for one, two, and seven days admitted. Need to generate flags for 3, 4, 5, 6 days admitted--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_26` AS
SELECT *, DATETIME_ADD(intime, INTERVAL 3 DAY) AS threedays_admitted, DATETIME_ADD(intime, INTERVAL 4 DAY) AS fourdays_admitted, DATETIME_ADD(intime, INTERVAL 5 DAY) AS fivedays_admitted, DATETIME_ADD(intime, INTERVAL 6 DAY) AS sixdays_admitted
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_25`;
--For each of the pressors, determine if the patient received them on days 1 - 7 (Y/N)-- 
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.dobutamine` AS
WITH dobutamine AS(
    SELECT s.*,d.starttime, d.endtime
      FROM `physionet-data.mimiciv_3_1_derived.dobutamine` d
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_26` s
          ON d.stay_id = s.stay_id
)
SELECT dobut.stay_id,
MAX(CASE WHEN dobut.starttime < dobut.oneday_admitted 
          AND dobut.endtime > dobut.intime 
          THEN 1 ELSE 0 END) AS day1_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.admitted_48_hrs 
          AND dobut.endtime > dobut.oneday_admitted
          THEN 1 ELSE 0 END) AS day2_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.threedays_admitted 
          AND dobut.endtime > dobut.admitted_48_hrs
          THEN 1 ELSE 0 END) AS day3_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.fourdays_admitted 
          AND dobut.endtime > dobut.threedays_admitted 
          THEN 1 ELSE 0 END) AS day4_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.fivedays_admitted 
          AND dobut.endtime > dobut.fourdays_admitted
          THEN 1 ELSE 0 END)AS day5_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.sixdays_admitted 
          AND dobut.endtime > dobut.fivedays_admitted 
          THEN 1 ELSE 0 END) AS day6_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.sevendays_admitted 
          AND dobut.endtime > dobut.sevendays_admitted
          THEN 1 ELSE 0 END) AS day7_dobutamine
FROM dobutamine dobut
GROUP BY dobut.stay_id;

---Repeating the process for dopamine--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.dopamine` AS
WITH dopamine AS(
    SELECT s.*,d.starttime, d.endtime
      FROM `physionet-data.mimiciv_3_1_derived.dopamine` d
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_26` s
          ON d.stay_id = s.stay_id
)
SELECT dop.stay_id,
MAX(CASE WHEN dop.starttime < dop.oneday_admitted 
          AND dop.endtime > dop.intime 
          THEN 1 ELSE 0 END) AS day1_dopamine,
MAX(CASE WHEN dop.starttime < dop.admitted_48_hrs 
          AND dop.endtime > dop.oneday_admitted
          THEN 1 ELSE 0 END) AS day2_dopamine,
MAX(CASE WHEN dop.starttime < dop.threedays_admitted 
          AND dop.endtime > dop.admitted_48_hrs
          THEN 1 ELSE 0 END) AS day3_dopamine,
MAX(CASE WHEN dop.starttime < dop.fourdays_admitted 
          AND dop.endtime > dop.threedays_admitted 
          THEN 1 ELSE 0 END) AS day4_dopamine,
MAX(CASE WHEN dop.starttime < dop.fivedays_admitted 
          AND dop.endtime > dop.fourdays_admitted
          THEN 1 ELSE 0 END)AS day5_dopamine,
MAX(CASE WHEN dop.starttime < dop.sixdays_admitted 
          AND dop.endtime > dop.fivedays_admitted 
          THEN 1 ELSE 0 END) AS day6_dopamine,
MAX(CASE WHEN dop.starttime < dop.sevendays_admitted 
          AND dop.endtime > dop.sevendays_admitted
          THEN 1 ELSE 0 END) AS day7_dopamine
FROM dopamine dop
GROUP BY dop.stay_id;

---Repeating the process for epinephrine--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.epinephrine` AS
WITH epinephrine AS(
    SELECT s.*,e.starttime, e.endtime
      FROM `physionet-data.mimiciv_3_1_derived.epinephrine` e
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_26` s
          ON e.stay_id = s.stay_id
)
SELECT epi.stay_id,
MAX(CASE WHEN epi.starttime < epi.oneday_admitted 
          AND epi.endtime > epi.intime 
          THEN 1 ELSE 0 END) AS day1_epi,
MAX(CASE WHEN epi.starttime < epi.admitted_48_hrs 
          AND epi.endtime > epi.oneday_admitted
          THEN 1 ELSE 0 END) AS day2_epi,
MAX(CASE WHEN epi.starttime < epi.threedays_admitted 
          AND epi.endtime > epi.admitted_48_hrs
          THEN 1 ELSE 0 END) AS day3_epi,
MAX(CASE WHEN epi.starttime < epi.fourdays_admitted 
          AND epi.endtime > epi.threedays_admitted 
          THEN 1 ELSE 0 END) AS day4_epi,
MAX(CASE WHEN epi.starttime < epi.fivedays_admitted 
          AND epi.endtime > epi.fourdays_admitted
          THEN 1 ELSE 0 END)AS day5_epi,
MAX(CASE WHEN epi.starttime < epi.sixdays_admitted 
          AND epi.endtime > epi.fivedays_admitted 
          THEN 1 ELSE 0 END) AS day6_epi,
MAX(CASE WHEN epi.starttime < epi.sevendays_admitted 
          AND epi.endtime > epi.sevendays_admitted
          THEN 1 ELSE 0 END) AS day7_epi
FROM epinephrine epi
GROUP BY epi.stay_id;
---Repeating the process for norepinephrine--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.norepinephrine` AS
WITH norepinephrine AS(
    SELECT s.*,n.starttime, n.endtime
      FROM `physionet-data.mimiciv_3_1_derived.norepinephrine` n
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_26` s
          ON n.stay_id = s.stay_id
)
SELECT ne.stay_id,
MAX(CASE WHEN ne.starttime < ne.oneday_admitted 
          AND ne.endtime > ne.intime 
          THEN 1 ELSE 0 END) AS day1_norepi,
MAX(CASE WHEN ne.starttime < ne.admitted_48_hrs 
          AND ne.endtime > ne.oneday_admitted
          THEN 1 ELSE 0 END) AS day2_norepi,
MAX(CASE WHEN ne.starttime < ne.threedays_admitted 
          AND ne.endtime > ne.admitted_48_hrs
          THEN 1 ELSE 0 END) AS day3_norepi,
MAX(CASE WHEN ne.starttime < ne.fourdays_admitted 
          AND ne.endtime > ne.threedays_admitted 
          THEN 1 ELSE 0 END) AS day4_norepi,
MAX(CASE WHEN ne.starttime < ne.fivedays_admitted 
          AND ne.endtime > ne.fourdays_admitted
          THEN 1 ELSE 0 END)AS day5_norepi,
MAX(CASE WHEN ne.starttime < ne.sixdays_admitted 
          AND ne.endtime > ne.fivedays_admitted 
          THEN 1 ELSE 0 END) AS day6_norepi,
MAX(CASE WHEN ne.starttime < ne.sevendays_admitted 
          AND ne.endtime > ne.sevendays_admitted
          THEN 1 ELSE 0 END) AS day7_norepi
FROM norepinephrine ne
GROUP BY ne.stay_id;

---Repeating the process for vasopressin--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.vasopressin` AS
WITH vasopressin AS(
    SELECT s.*,v.starttime, v.endtime
      FROM `mimic-iv-ext-2025.FAI_Sepsis.vasopressin_alldata` v
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_26` s
          ON v.stay_id = s.stay_id
)
SELECT vaso.stay_id,
MAX(CASE WHEN vaso.starttime < vaso.oneday_admitted 
          AND vaso.endtime > vaso.intime 
          THEN 1 ELSE 0 END) AS day1_vasopressin,
MAX(CASE WHEN vaso.starttime < vaso.admitted_48_hrs 
          AND vaso.endtime > vaso.oneday_admitted
          THEN 1 ELSE 0 END) AS day2_vasopressin,
MAX(CASE WHEN vaso.starttime < vaso.threedays_admitted 
          AND vaso.endtime > vaso.admitted_48_hrs
          THEN 1 ELSE 0 END) AS day3_vasopressin,
MAX(CASE WHEN vaso.starttime < vaso.fourdays_admitted 
          AND vaso.endtime > vaso.threedays_admitted 
          THEN 1 ELSE 0 END) AS day4_vasopressin,
MAX(CASE WHEN vaso.starttime < vaso.fivedays_admitted 
          AND vaso.endtime > vaso.fourdays_admitted
          THEN 1 ELSE 0 END)AS day5_vasopressin,
MAX(CASE WHEN vaso.starttime < vaso.sixdays_admitted 
          AND vaso.endtime > vaso.fivedays_admitted 
          THEN 1 ELSE 0 END) AS day6_vasopressin,
MAX(CASE WHEN vaso.starttime < vaso.sevendays_admitted 
          AND vaso.endtime > vaso.sevendays_admitted
          THEN 1 ELSE 0 END) AS day7_vasopressin
FROM vasopressin vaso
GROUP BY vaso.stay_id;

--Merging all of our pressor datasets to our main dataset--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_27` AS
SELECT s.*,
       dobut.day1_dobutamine, dobut.day2_dobutamine, dobut.day3_dobutamine, dobut.day4_dobutamine, dobut.day5_dobutamine, dobut.day6_dobutamine, dobut.day7_dobutamine,
       dop.day1_dopamine, dop.day2_dopamine, dop.day3_dopamine, dop.day4_dopamine, dop.day5_dopamine, dop.day6_dopamine, dop.day7_dopamine,
       epi.day1_epi, epi.day2_epi, epi.day3_epi, epi.day4_epi, epi.day5_epi, epi.day6_epi, epi.day7_epi,
       ne.day1_norepi, ne.day2_norepi, ne.day3_norepi, ne.day4_norepi, ne.day5_norepi, ne.day6_norepi, ne.day7_norepi,
       v.day1_vasopressin, v.day2_vasopressin, v.day3_vasopressin, v.day4_vasopressin, v.day5_vasopressin, v.day6_vasopressin, v.day7_vasopressin
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_26` s
  LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.dobutamine` dobut
  ON s.stay_id = dobut.stay_id 
    LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.dopamine` dop
      ON s.stay_id = dop.stay_id
        LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.epinephrine` epi
          ON s.stay_id = epi.stay_id
            LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.norepinephrine` ne
              ON s.stay_id = ne.stay_id
                LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.vasopressin` v
                  ON s.stay_id = v.stay_id;



##########################Step 13: Bringing in NED##########################

--Selecting the maximum NED on days 1-7 for each patient--
--Day 1--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.ned_d1_max` AS
WITH ned AS(
    SELECT s.*,n.starttime, n.endtime, n.norepinephrine_equivalent_dose
      FROM `physionet-data.mimiciv_3_1_derived.norepinephrine_equivalent_dose` n
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_27` s
          ON n.stay_id = s.stay_id
)
SELECT ned.stay_id,MAX(ned.norepinephrine_equivalent_dose) AS day1_peak_NED
FROM ned ned
WHERE ned.starttime < ned.oneday_admitted 
          AND ned.endtime > ned.intime 
GROUP BY ned.stay_id;

--Day 2--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.ned_d2_max` AS
WITH ned AS(
    SELECT s.*,n.starttime, n.endtime, n.norepinephrine_equivalent_dose
      FROM `physionet-data.mimiciv_3_1_derived.norepinephrine_equivalent_dose` n
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_27` s
          ON n.stay_id = s.stay_id
)
SELECT ned.stay_id,MAX(ned.norepinephrine_equivalent_dose) AS day2_peak_NED
FROM ned ned
WHERE ned.starttime < ned.admitted_48_hrs 
          AND ned.endtime > ned.oneday_admitted
GROUP BY ned.stay_id;

--Day 3--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.ned_d3_max` AS
