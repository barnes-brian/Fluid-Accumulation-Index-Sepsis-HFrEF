FROM `physionet-data.mimiciv_3_1_icu.chartevents` 
WHERE itemid IN (226457,226499)  AND stay_id = 39378254 AND charttime BETWEEN  '2117-11-10T18:25:00' and '2117-11-12T18:25:00' and valueuom = 'mL';


--Merging fluid balance data into dataset with all variables--


CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample_final` AS
SELECT a.*, f.total_in_sepsis_onset, f.total_out_sepsis_onset, (f.total_in_sepsis_onset - f.total_out_sepsis_onset) AS fb_sepsis_onset, ((f.total_in_sepsis_onset - f.total_out_sepsis_onset)/f.total_in_sepsis_onset) AS fai_sepsis_onset, DATETIME_DIFF(outtime, sepsis_onset_datetime, HOUR) AS hrs_between_sepsisonset_discharge
  FROM `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample` a
  LEFT JOIN
    `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample_fb_sepsis_onset` f
      ON a.stay_id = f.stay_id
        LEFT JOIN `physionet-data.mimiciv_3_1_icu.icustays` i
          ON a.stay_id = i.stay_id;


SELECT COUNT(DISTINCT stay_id)
  FROM `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample_final`
    WHERE fai_sepsis_onset <= 0.42;

SELECT COUNT(DISTINCT stay_id)
  FROM `mimic-iv-ext-2025.FAI_Sepsis.analytic_sample_final`
    WHERE fai_sepsis_onset > 0.42;
