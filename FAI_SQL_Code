--Weight--
--Need so we can calculate fluid balance in mL/kg--

--https://github.com/MIT-LCP/mimic-code/blob/main/mimic-iv/concepts/firstday/first_day_weight.sql--
-- This query extracts weights for adult ICU patients on their first ICU day.
-- It does *not* use any information after the first ICU day, as weight is
-- sometimes used to monitor fluid balance.
-- The MIMIC-III version used echodata but this isn't available in MIMIC-IV.

CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.admitweight` AS
SELECT
    ie.subject_id
    , ie.stay_id
    , AVG(
        CASE WHEN weight_type = 'admit' THEN ce.weight ELSE NULL END
    ) AS weight_admit
    , AVG(ce.weight) AS weight
    , MIN(ce.weight) AS weight_min
    , MAX(ce.weight) AS weight_max
FROM `physionet-data.mimiciv_3_1_icu.icustays` ie
-- admission weight
LEFT JOIN `physionet-data.mimiciv_3_1_derived.weight_durations` ce
    ON ie.stay_id = ce.stay_id
        -- we filter to weights documented during or before the 1st day
        AND ce.starttime <= DATETIME_ADD(ie.intime, INTERVAL '1' DAY)
GROUP BY ie.subject_id, ie.stay_id
;

CREATE OR REPLACE TABLE  `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_25` AS
SELECT s.*, w.weight AS average_d1_weight, w.weight_admit AS icuadmit_weight, w.weight_min min_d1_weight, w.weight_max max_d1_weight
  FROM  `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_24` s
    LEFT JOIN `mimic-iv-ext-2025.FAI_Sepsis.admitweight` w
      ON s.stay_id = w.stay_id;

##########################Bringing in vasopressor frequencies##########################

--Previously created flags for one, two, and seven days admitted. Need to generate flags for 3, 4, 5, 6 days admitted--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_26` AS
SELECT *, DATETIME_ADD(intime, INTERVAL 3 DAY) AS threedays_admitted, DATETIME_ADD(intime, INTERVAL 4 DAY) AS fourdays_admitted, DATETIME_ADD(intime, INTERVAL 5 DAY) AS fivedays_admitted, DATETIME_ADD(intime, INTERVAL 6 DAY) AS sixdays_admitted
FROM `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_25`;

--For each of the pressors, determine if the patient received them on days 1 - 7 (Y/N)-- 
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.dobutamine` AS
WITH dobutamine AS(
    SELECT s.*,d.starttime, d.endtime
      FROM `physionet-data.mimiciv_3_1_derived.dobutamine` d
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_26` s
          ON d.stay_id = s.stay_id
)
SELECT dobut.stay_id,
MAX(CASE WHEN dobut.starttime < dobut.oneday_admitted 
          AND dobut.endtime > dobut.intime 
          THEN 1 ELSE 0 END) AS day1_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.admitted_48_hrs 
          AND dobut.endtime > dobut.oneday_admitted
          THEN 1 ELSE 0 END) AS day2_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.threedays_admitted 
          AND dobut.endtime > dobut.admitted_48_hrs
          THEN 1 ELSE 0 END) AS day3_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.fourdays_admitted 
          AND dobut.endtime > dobut.threedays_admitted 
          THEN 1 ELSE 0 END) AS day4_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.fivedays_admitted 
          AND dobut.endtime > dobut.fourdays_admitted
          THEN 1 ELSE 0 END)AS day5_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.sixdays_admitted 
          AND dobut.endtime > dobut.fivedays_admitted 
          THEN 1 ELSE 0 END) AS day6_dobutamine,
MAX(CASE WHEN dobut.starttime < dobut.sevendays_admitted 
          AND dobut.endtime > dobut.sevendays_admitted
          THEN 1 ELSE 0 END) AS day7_dobutamine
FROM dobutamine dobut
GROUP BY dobut.stay_id;

---Repeating the process for dopamine--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.dopamine` AS
WITH dopamine AS(
    SELECT s.*,d.starttime, d.endtime
      FROM `physionet-data.mimiciv_3_1_derived.dopamine` d
        RIGHT  JOIN `mimic-iv-ext-2025.FAI_Sepsis.septic_hfref_full_26` s
          ON d.stay_id = s.stay_id
)
SELECT dop.stay_id,
MAX(CASE WHEN dop.starttime < dop.oneday_admitted 
          AND dop.endtime > dop.intime 
          THEN 1 ELSE 0 END) AS day1_dopamine,
MAX(CASE WHEN dop.starttime < dop.admitted_48_hrs 
          AND dop.endtime > dop.oneday_admitted
          THEN 1 ELSE 0 END) AS day2_dopamine,
MAX(CASE WHEN dop.starttime < dop.threedays_admitted 
          AND dop.endtime > dop.admitted_48_hrs
          THEN 1 ELSE 0 END) AS day3_dopamine,
MAX(CASE WHEN dop.starttime < dop.fourdays_admitted 
          AND dop.endtime > dop.threedays_admitted 
          THEN 1 ELSE 0 END) AS day4_dopamine,
MAX(CASE WHEN dop.starttime < dop.fivedays_admitted 
          AND dop.endtime > dop.fourdays_admitted
          THEN 1 ELSE 0 END)AS day5_dopamine,
MAX(CASE WHEN dop.starttime < dop.sixdays_admitted 
          AND dop.endtime > dop.fivedays_admitted 
          THEN 1 ELSE 0 END) AS day6_dopamine,
MAX(CASE WHEN dop.starttime < dop.sevendays_admitted 
          AND dop.endtime > dop.sevendays_admitted
          THEN 1 ELSE 0 END) AS day7_dopamine
FROM dopamine dop
GROUP BY dop.stay_id;

---Repeating the process for epinephrine--
CREATE OR REPLACE TABLE `mimic-iv-ext-2025.FAI_Sepsis.epinephrine` AS
WITH epinephrine AS(
    SELECT s.*,e.starttime, e.endtime
